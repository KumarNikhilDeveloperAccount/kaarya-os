# -------------------------------------------------------------
# Kaarya.OS Environment Variables
# COPY THIS FILE TO .env AND FILL IN YOUR SECRETS!
# DO NOT COMMIT THE .env FILE TO GIT!
# -------------------------------------------------------------

# --- Database & Redis ---
DATABASE_URL=postgresql://kaarya_user:kaarya_password@localhost:5433/kaarya_os
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Ensure this is a strong randomly generated key in production.
SECRET_KEY=supersecretkey-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 Hours for candidate convenience

# --- 1. Vertex AI (Yukti.ai Integration) ---
# Project ID inside your Google Cloud Console
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Path to your service account JSON file, or leave blank if using `gcloud auth application-default login`
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# --- 2. Razorpay (Payments) ---
# Generate these under "API Keys" in your Razorpay Dashboard
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# --- 3. Crisp (Support / Ticketing Chat) ---
# Found in Crisp Dashboard -> Settings -> Website Settings -> Integrations
CRISP_WEBSITE_ID=your-crisp-website-id

# --- 4. Email / Communications (Optional for now, but needed for Phase 15) ---
# Email OTP mode:
# - console: prints OTP to backend console (dev)
# - smtp: sends OTP via SMTP_* settings
EMAIL_MODE=console
# If using SMTP (Gmail, AWS SES, etc.):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Kaarya.OS <your-email@gmail.com>
OTP_EXPIRE_MINUTES=10
OTP_DEBUG_RETURN_CODE=false
# Or if using Resend/SendGrid:
EMAIL_API_KEY=your-email-api-key

# --- 5. Firebase Admin (for verifying Firebase ID Tokens) ---
# If running locally without ADC, point to a service account JSON file.
FIREBASE_SERVICE_ACCOUNT_FILE=/path/to/firebase-service-account.json

# --- 6. LinkedIn OAuth (Login) ---
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Must be an exact redirect URL whitelisted in LinkedIn Developer Portal (no #, query params ignored)
LINKEDIN_REDIRECT_URL=http://127.0.0.1:8000/api/auth/linkedin/callback
LINKEDIN_SCOPES=r_liteprofile r_emailaddress
FRONTEND_BASE_URL=http://localhost:3000
